{
  "name": "@mondrakebr1/specskills",
  "version": "1.3.9",
  "description": "Context Engineering extension for Windsurf - spec-driven development framework",
  "main": "dist/index.js",
  "bin": {
    "conductor": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run clean && tsc",
    "watch": "tsc --watch",
    "clean": "rimraf dist",
    "check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "windsurf",
    "context-engineering",
    "spec-driven",
    "conductor",
    "boilerplate"
  ],
  "author": "Conductor Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/conductor-engine/conductor"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "yaml": "^2.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
